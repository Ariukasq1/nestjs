generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin-arm64", "linux-musl", "linux-arm64-openssl-1.1.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Redeemable {
  id                Int               @id @default(autoincrement())
  code              Int?
  type              String?
  claimBeginAt      DateTime?
  claimEndAt        DateTime?
  createdAt         DateTime          @default(now())
  redeemableGroup   RedeemableGroup?  @relation(fields: [redeemableGroupId], references: [id])
  redeemableGroupId Int?
  isReclaimable     Boolean           @default(false)
  redeemableClaim   RedeemableClaim[]
}

model RedeemableGroup {
  id         Int          @id @default(autoincrement())
  name       String
  redeemable Redeemable[]
}

model RedeemableClaim {
  id           Int        @id @default(autoincrement())
  redeemadble  Redeemable @relation(fields: [redeeambleId], references: [id])
  redeeambleId Int
  userId       Int
}

model EventHandler {
  id          Int           @id @default(autoincrement())
  triggerType String
  triggerId   Int
  eventResult EventResult[]
}

model EventResult {
  id             Int          @id @default(autoincrement())
  resultType     String
  resultId       Int
  eventHandler   EventHandler @relation(fields: [eventHandlerId], references: [id])
  eventHandlerId Int
}
